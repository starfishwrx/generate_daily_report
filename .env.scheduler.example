# Copy to .env.scheduler and fill real values.
# This file is sourced by scripts/run_daily_report.sh.

FEISHU_APP_ID="cli_xxx"
FEISHU_APP_SECRET="your_secret"
FEISHU_DOC_FOLDER_TOKEN=""

# Optional runtime tuning
MAX_RETRIES="3"
RETRY_DELAY_SECONDS="300"
DATE_MODE="yesterday"
RUN_AUTH_CHECK="1"
RUN_AUTH_REPAIR="1"
AUTH_REPAIR_BROWSER="chrome"
AUTH_REPAIR_PROFILE="output/auth_profiles/chrome_daily_report"
AUTH_REPAIR_TIMEOUT_SECONDS="300"
AUTH_REPAIR_TARGET="auto"
VERIFY_FEISHU_CONTENT="0"
DISABLE_FEISHU_PUSH="0"
